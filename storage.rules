rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Event icon (favicon) — authenticated users can read/upload, max 512KB images
    match /events/{eventId}/icon.{ext} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 512 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Program hero images — authenticated users can read, authenticated can upload
    match /events/{eventId}/programs/{programId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Photo wall uploads — authenticated users can read/upload, max 5MB images
    match /events/{eventId}/photos/{viewerId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == viewerId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
