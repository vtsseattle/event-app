rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Event document — authenticated read, admin write
    match /events/{eventId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Programs — authenticated read, admin write (CRUD from admin panel)
    match /events/{eventId}/programs/{programId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Viewers — authenticated users can read all, write own doc, admin can delete
    match /events/{eventId}/viewers/{viewerId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
                            && request.auth.uid == viewerId;
      allow delete: if request.auth != null;
    }

    // Reactions — authenticated users can read all, create their own, admin can delete
    match /events/{eventId}/reactions/{reactionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.viewerId == request.auth.uid;
      allow delete: if request.auth != null;
    }

    // Shoutouts — authenticated read/create, admin can update status (flag/delete)
    match /events/{eventId}/shoutouts/{shoutoutId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.viewerId == request.auth.uid
                    && request.resource.data.text is string
                    && request.resource.data.text.size() <= 200;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Trivia questions — authenticated read, admin write
    match /events/{eventId}/trivia/{questionId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Trivia answers — authenticated read, create own answer
    match /events/{eventId}/triviaAnswers/{answerId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.viewerId == request.auth.uid;
      allow delete: if request.auth != null;
    }

    // Photos — authenticated read/create, admin can update status (approve/reject)
    match /events/{eventId}/photos/{photoId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.viewerId == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Pledges — authenticated read/create, admin can manage
    match /events/{eventId}/pledges/{pledgeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.viewerId == request.auth.uid;
      allow update, delete: if request.auth != null;
    }

    // Feedback — anonymous create, admin read
    match /events/{eventId}/feedback/{feedbackId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.rating is int
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5;
      allow update, delete: if request.auth != null;
    }
  }
}
